{
  "expo": {
    "name": "PetCareNow",
    "slug": "PetCareNow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/PCNLogo.png",
    "scheme": "petcarenow",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/PCNLogo.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/PCNLogo.png",
        "backgroundImage": "./assets/images/PCNLogo.png",
        "monochromeImage": "./assets/images/PCNLogo.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/PCNLogo.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "PetCareNow necesita acceso a tus fotos para elegir la imagen de tu mascota.",
          "cameraPermission": "PetCareNow necesita acceso a tu cámara para tomar una foto de tu mascota.",
          "microphonePermission": false
        }
      ],
      "@react-native-vector-icons/ionicons",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
