  "scripts": {
    "start": "expo start",
    "start:dev": "expo start",
    "doctor:expo": "CURRENT_PID=$$; PARENT_PID=$PPID; ps -Ao pid=,command= | awk -v self=\"$CURRENT_PID\" -v parent=\"$PARENT_PID\" '($1 != self && $1 != parent) && $0 ~ /\\/Users\\/joserodriguez\\/Desktop\\/PetCareNow\\/node_modules\\/\\.bin\\/expo (start|run:ios|run:android)/ { print $1 }' | xargs kill -9 2>/dev/null || true; watchman watch-del-all || true; rm -rf .expo",
    "deps:check": "npx expo install --check",
    "start:clean": "npm run doctor:expo && npx expo start --clear",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios:dev": "npx expo run:ios --device 'iPhone 16e'",
    "ios:clean": "npm run doctor:expo && npx expo run:ios --device 'iPhone 16e'",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "moduleNameMapper": {
      "^@/assets/(.*)$": "<rootDir>/assets/$1",
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "watchman": false,
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.expo/"
    ]
  },
  "private": true
}
